# SecureDock Environment Variables
# Copy to .env and fill in your values

# Required for AI triage tracks
ANTHROPIC_API_KEY=

# Optional - if not set, scanner runs in DEMO_MODE with realistic mock data
SNYK_TOKEN=

# Optional - enables AI agent to open fix PRs automatically
GITHUB_TOKEN=
GITHUB_REPO=leo-876/SecureDock

# Pipeline event context: push | pr | merge
PIPELINE_EVENT=push

# Force demo mode even if SNYK_TOKEN is set
DEMO_MODE=false
